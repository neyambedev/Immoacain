# ============================================================
#  ACAIN IMMOBILIER — Variables d'environnement
#  Copiez ce fichier en  .env  et remplissez les valeurs.
#  Ne committez JAMAIS le fichier .env sur GitHub !
# ============================================================

# Clé secrète Django (générez-en une avec la commande ci-dessous)
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=remplacez-par-une-vraie-cle-secrete

# False en production, True en développement
DJANGO_DEBUG=False

# Votre domaine de production (séparés par des virgules)
DJANGO_ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com
